{
  "name": "pronax-ai-web",
  "version": "1.0.0",
  "description": "ProNax AI Web Interface - 3D Spatial Intelligence",
  "main": "index.html",
  "scripts": {
    "build-css": "tailwindcss -i ./src/input.css -o ./dist/output.css --watch",
    "build-css-prod": "tailwindcss -i ./src/input.css -o ./dist/output.css --minify",
    "serve": "python -m http.server 8080",
    "dev": "concurrently \"npm run build-css\" \"npm run serve\""
  },
  "keywords": [
    "ai",
    "3d-spatial",
    "web-interface",
    "pronax",
    "chat"
  ],
  "author": "ZKG",
  "license": "MIT",
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.7",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6"
  }
}
