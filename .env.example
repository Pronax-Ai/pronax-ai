# ProNax AI Environment Configuration
# Copy this file to .env and fill in your values

# API Configuration
PRONAX_API_PORT=8080
PRONAX_API_HOST=0.0.0.0
PRONAX_API_KEY=your-secret-api-key-here

# Model Configuration
PRONAX_MODEL=gemma-4-9b-it
PRONAX_MODEL_PATH=/home/pronax/.pronax/models
PRONAX_QUANTIZATION=q4_k_m
PRONAX_SPATIAL_OPTIMIZATION=true
PRONAX_CONTEXT_SIZE=4096

# 3D Spatial Configuration
PRONAX_3D_SPATIAL_ENABLED=true
PRONAX_3D_SPATIAL_LEVEL=2
PRONAX_KV_CACHE_SPATIAL=true

# GPU Configuration
PRONAX_GPU_BACKEND=auto
PRONAX_CUDA_VISIBLE_DEVICES=0
PRONAX_METAL_DEVICE=auto

# Performance Configuration
PRONAX_MAX_CONCURRENT_REQUESTS=100
PRONAX_REQUEST_TIMEOUT=120
PRONAX_BATCH_SIZE=1
PRONAX_TEMPERATURE=0.7

# Logging Configuration
RUST_LOG=info
PRONAX_LOG_LEVEL=info
PRONAX_LOG_FILE=/app/logs/pronax.log

# Security Configuration
PRONAX_CORS_ORIGINS=*
PRONAX_RATE_LIMIT_REQUESTS=100
PRONAX_RATE_LIMIT_WINDOW=60

# Database Configuration (if using external storage)
# PRONAX_DATABASE_URL=postgresql://user:password@localhost/pronax
# PRONAX_REDIS_URL=redis://localhost:6379

# Monitoring Configuration
PRONAX_METRICS_ENABLED=true
PRONAX_METRICS_PORT=9090
PRONAX_HEALTH_CHECK_INTERVAL=30

# Deployment Configuration
DEPLOYMENT_ENV=production
DOCKER_REGISTRY=zkg786
DOCKER_IMAGE=pronax-ai
VERSION_TAG=latest
